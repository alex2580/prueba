    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:.75rem;margin-top:1rem;">
    <div class="arch-box" style="text-align:center;padding:.75rem;">
      <span style="font-size:1.5rem;">🗄️</span>
