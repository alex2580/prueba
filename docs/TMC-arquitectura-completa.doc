  </div>
</div>

<!-- TOC -->
<div class="toc">
  <h3>📋 Índice de Contenidos</h3>
  <ol>
    <li><a href="#resumen">Resumen Ejecutivo</a></li>
    <li><a href="#stack">Stack Tecnológico</a></li>
    <li><a href="#arquitectura">Arquitectura General</a></li>
    <li><a href="#infraestructura">Infraestructura y Deploy</a></li>
