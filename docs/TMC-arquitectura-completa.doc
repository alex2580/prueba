<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TodasMisCosas — Documentación Técnica Completa</title>
<style>
  :root {
    --bg: #0a0e1a; --surface: #111827; --surface2: #1a2235; --border: #1e2d45;
    --orange: #e8622a; --mint: #10b981; --blue: #3b82f6; --amber: #f59e0b;
    --red: #ef4444; --text: #e2e8f0; --text2: #94a3b8; --text3: #64748b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Segoe UI', system-ui, sans-serif; background: var(--bg); color: var(--text); line-height: 1.65; font-size: 14px; }
  .page { max-width: 1100px; margin: 0 auto; padding: 3rem 2rem; }

  h1 { font-size: 2.2rem; font-weight: 900; color: var(--orange); margin-bottom: .4rem; }
  h2 { font-size: 1.35rem; font-weight: 800; color: var(--orange); margin: 2.5rem 0 1rem; padding-bottom: .4rem; border-bottom: 2px solid var(--orange); }
  h3 { font-size: 1.05rem; font-weight: 700; color: var(--mint); margin: 1.6rem 0 .6rem; }
  h4 { font-size: .9rem; font-weight: 700; color: var(--amber); margin: 1.2rem 0 .4rem; }
  p  { color: var(--text2); margin-bottom: .75rem; }

  .cover { text-align: center; padding: 3rem 0 2.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem; }
  .cover .subtitle { font-size: 1rem; color: var(--text3); margin-top: .4rem; }
  .cover .meta { display: flex; justify-content: center; gap: 2rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .cover .meta span { background: var(--surface2); border: 1px solid var(--border); border-radius: 999px; padding: .3rem .9rem; font-size: .78rem; color: var(--text2); }

  table { width: 100%; border-collapse: collapse; margin: .75rem 0 1.2rem; font-size: .83rem; }
  th { background: var(--surface2); color: var(--orange); font-weight: 700; text-align: left; padding: .55rem .8rem; border: 1px solid var(--border); }
  td { padding: .45rem .8rem; border: 1px solid var(--border); color: var(--text2); vertical-align: top; }
  tr:nth-child(even) td { background: rgba(255,255,255,.02); }

  code { font-family: 'Courier New', monospace; font-size: .82em; background: var(--surface2); color: var(--mint); padding: .1em .35em; border-radius: 3px; }
  pre  { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.2rem; overflow-x: auto; margin: .75rem 0 1.2rem; }
  pre code { background: none; padding: 0; font-size: .82rem; color: #93c5fd; }

  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin: .75rem 0; }
  .grid3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1rem; margin: .75rem 0; }
  .box { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 1rem 1.2rem; }
  .box h4 { margin-top: 0; }
  .box ul { padding-left: 1.2rem; color: var(--text2); }
  .box ul li { margin-bottom: .25rem; font-size: .83rem; }

  .tag { display: inline-block; border-radius: 999px; padding: .15rem .6rem; font-size: .7rem; font-weight: 700; margin-right: .3rem; }
  .tag-green  { background: rgba(16,185,129,.15); color: var(--mint); }
  .tag-orange { background: rgba(232,98,42,.15);  color: var(--orange); }
  .tag-blue   { background: rgba(59,130,246,.15); color: var(--blue); }
  .tag-red    { background: rgba(239,68,68,.15);  color: var(--red); }

  .flow { display: flex; align-items: center; flex-wrap: wrap; gap: .5rem; margin: .6rem 0; }
  .flow-step { background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: .3rem .7rem; font-size: .78rem; color: var(--text2); }
  .flow-arrow { color: var(--orange); font-weight: 700; }

  .alert { background: rgba(245,158,11,.08); border: 1px solid rgba(245,158,11,.3); border-radius: 6px; padding: .7rem 1rem; margin: .6rem 0; color: var(--amber); font-size: .83rem; }

  .method { display: inline-block; font-weight: 800; font-size: .72rem; padding: .15rem .5rem; border-radius: 3px; margin-right: .4rem; font-family: monospace; }
  .GET    { background: rgba(16,185,129,.2);  color: var(--mint); }
  .POST   { background: rgba(59,130,246,.2);  color: var(--blue); }
  .PUT    { background: rgba(245,158,11,.2);  color: var(--amber); }
  .PATCH  { background: rgba(168,85,247,.2);  color: #c084fc; }
  .DELETE { background: rgba(239,68,68,.2);   color: var(--red); }

  .endpoint { background: var(--surface); border: 1px solid var(--border); border-radius: 6px; padding: .5rem .9rem; margin: .3rem 0; font-family: monospace; font-size: .82rem; color: var(--text); }
  .endpoint .desc { font-family: sans-serif; font-size: .78rem; color: var(--text3); margin-top: .1rem; }

  .toc { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 1.5rem; margin-bottom: 2.5rem; }
  .toc h3 { margin-top: 0; color: var(--orange); }
  .toc ol { padding-left: 1.4rem; }
  .toc li { margin: .3rem 0; }
  .toc a { color: var(--blue); text-decoration: none; font-size: .88rem; }
  .toc a:hover { color: var(--orange); }

  .arch-diagram { display: grid; grid-template-columns: 1fr auto 1fr auto 1fr; gap: 0; align-items: center; margin: 1rem 0; }
  .arch-box { background: var(--surface2); border: 2px solid var(--border); border-radius: 10px; padding: 1rem; text-align: center; }
  .arch-box.primary { border-color: var(--orange); }
  .arch-box .icon { font-size: 2rem; display: block; margin-bottom: .4rem; }
  .arch-box .label { font-weight: 800; font-size: .88rem; color: var(--text); }
  .arch-box .sub { font-size: .72rem; color: var(--text3); margin-top: .2rem; }
  .arch-arrow { text-align: center; color: var(--orange); font-size: 1.5rem; padding: 0 .5rem; }

  hr { border: none; border-top: 1px solid var(--border); margin: 2rem 0; }
  @media (max-width: 700px) { .grid2, .grid3, .arch-diagram { grid-template-columns: 1fr; } .arch-arrow { transform: rotate(90deg); } }
</style>
</head>
<body>
<div class="page">

<!-- COVER -->
<div class="cover">
  <div style="font-size:3rem;margin-bottom:.5rem;">📦</div>
