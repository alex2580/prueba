# Server
PORT=4000
NODE_ENV=development

# MySQL (Hostinger)
DB_HOST=localhost
DB_PORT=3306
DB_USER=todasmiscosas_user
DB_PASS=your_mysql_password
DB_NAME=todasmiscosas_db

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret

# MercadoPago
MP_ACCESS_TOKEN=your_mp_access_token
MP_PUBLIC_KEY=your_mp_public_key
MP_WEBHOOK_SECRET=your_webhook_secret

# Email (Hostinger SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@todasmiscosas.com
SMTP_PASS=your_email_password

# Frontend URL (para CORS y redirects)
FRONTEND_URL=http://localhost:3000

# Upload (local o S3)
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
